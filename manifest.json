{
  "manifest_version": 3,
  "name": "Console Lens",
  "version": "1.0.0",
  "description": "Filter and explore nested console.log objects with dot-path queries in a dedicated DevTools panel",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page-script.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
